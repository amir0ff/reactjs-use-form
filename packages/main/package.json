{
  "name": "reactjs-use-form",
  "version": "1.7.3",
  "description": "Reactive form management and input field validation hook",
  "author": "amir0ff",
  "license": "MIT",
  "homepage": "https://amir0ff.github.io/reactjs-use-form",
  "repository": {
    "type": "git",
    "url": "https://github.com/amir0ff/reactjs-use-form"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "dev": "pnpm exec vite build --watch",
    "build": "pnpm exec vite build",
    "clean": "rm -rf node_modules dist"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.9",
    "@vitejs/plugin-react": "^5.1.2",
    "happy-dom": "^20.7.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "react",
    "typescript",
    "react-testing-library",
    "react-hooks"
  ]
}
